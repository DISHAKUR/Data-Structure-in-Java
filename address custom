        "showButton": true,
        "content": [
          {
            "type": "unordered-list",
            "items": [
              "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TEXT.PARAGRAPH-0}",
              "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TEXT.PARAGRAPH-1}",
              [
                "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TEXT.PARAGRAPH-2:{websiteLink: ?}}",
                {
                  "type": "external-link",
                  "href": "https://finder.eircode.ie/",
                  "target": "_blank",
                  "content": "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TEXT.EIRCODE-WEBSITE}"
                }
              ],
              [
                "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TEXT.PARAGRAPH-3:{phoneNumber: ?}}",
                {
                  "type": "external-link",
                  "href": "tel:+35315534040",
                  "className": "text-nowrap",
                  "content": "01 553 4040"
                }
              ]
            ]
          }
        ]
      }
    },
    "forms": {
      "questions:address": [
        {
          "key": "address",
          "fieldGroup": [
            "{$if: store.enterManually !== true}",
            "{$if: store.enterEirCode !== true}",
