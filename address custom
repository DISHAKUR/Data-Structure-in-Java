                      "className": "underline",
                      "href": "{$intl: ADDRESS-LOOKUP.LINKS.EXCERCISE-RIGHTS.VALUE}",
                      "content": "{$intl: ADDRESS-LOOKUP.LINKS.EXCERCISE-RIGHTS.TEXT}",
                      "target": "_blank"
                    },
                    {
                      "type": "external-link",
                      "className": "underline",
                      "href": "{$intl: ADDRESS-LOOKUP.LINKS.PROCESSING-DATA.VALUE}",
                      "content": "{$intl: ADDRESS-LOOKUP.LINKS.PROCESSING-DATA.TEXT}",
                      "target": "_blank"
                    }
                  ]
                }
              },
              "validation": {
                "messages": {
                  "required": "{$intl: ADDRESS-LOOKUP.VALIDATION.REQUIRED-ADDRESS}",
                  "invalidAddress": [
                    {
                      "type": "paragraph",
                      "className": "mb-0",
                      "content": [
                        {
                          "type": "text",
                          "content": "{$intl: ADDRESS-LOOKUP.VALIDATION.NOT-FOUND-ADDRESS}"
                        },
                        {
                          "type": "text",
                          "content": "{$intl: ADDRESS-LOOKUP.VALIDATION.NOT-FOUND-ADDRESS-AFTER-TEXT}"
                        }
                      ]
                    }
                  ]
                }
              },
              "validators": {
                "validation": [
                  "valid-address"
                ]
              },
              "expressionProperties": {
                "templateOptions.tooManyResultsMessage.1": "' (' + field.templateOptions.foundTooManyResultsNumber + ') '",
                "templateOptions.required": "model.enterManually !== true"
              }
            },
            "{$if: store.enterEirCode === true}",
