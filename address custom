        "saveStore": {
          "key": "enterEirCode",
          "value": true
        }
      },
      {
        "saveStore": {
          "key": "enterManually",
          "value": false
        }
      }
    ],
    "ManualCustomerEirCode": [
      {
        "patchStore": {
          "key": "enterCustomerEirCode",
