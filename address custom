              "key": "address",
              "type": "address-lookup",
              "resetOnHide": true,
              "templateOptions": {
                "endpoints": {
                  "autocomplete": "@@nginxPrefix/geo/autocomplete",
                  "findaddress": "@@nginxPrefix/ie/geo/address"
                },
                "additionalHeaders": {
                  "x-api-key": "@@xApiKey"
                },
                "placeholder": "{$intl: ADDRESS-LOOKUP.INPUTS.ADDRESS.PLACEHOLDER}",
                "required": true,
                "noFloatingLabel": true,
                "hideRequiredMarker": true,
                "addressLookupIcon": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/liberty-icons-address.svg",
                "noResultsMessage": [
                  "{$intl: ADDRESS-LOOKUP.TEXT.NO-RESULTS}"
                ],
                "tooManyResultsMessage": [
                  "{$intl: ADDRESS-LOOKUP.TEXT.TOO-MANY-RESULTS}"
                ],
                "serviceNotRespondingMessage": [
                  "{$intl: ADDRESS-LOOKUP.TEXT.ADDRESS-SERVICE-NOT-RESPONDING}",
                  {
                    "type": "external-link",
                    "href": "tel:+35315534040",
                    "className": "text-nowrap",
                    "content": "01 553 4040"
                  }
                ],
                "tooltip": {
                  "iconUrl": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/helptext-icon.svg",
