{
  "events": {
    "ManualEntryA": [
      { "patchModel": { "key": "enterManually", "value": true } },
      { "patchModel": { "key": "enterEirCode", "value": false } }
    ],
    "ManualEirCode": [
      { "patchModel": { "key": "enterEirCode", "value": true } },
      { "patchModel": { "key": "enterManually", "value": false } }
    ],
    "ManualCustomerEntry": [
      { "patchModel": { "key": "enterCustomerManually", "value": true } },
      { "patchModel": { "key": "enterCustomerEirCode", "value": false } }
    ],
    "ManualCustomerEirCode": [
      { "patchModel": { "key": "enterCustomerEirCode", "value": true } },
      { "patchModel": { "key": "enterCustomerManually", "value": false } }
    ]
  },
  "body": {
    "heading": {
      "text": "{$var: store.customer.firstName} , {$intl: ADDRESS-LOOKUP.TITLE}"
    },
    "navigation": {
      "previousButton": {
        "hide": true
      }
    },
    "sections": {
      "cantFindAddress": {
        "title": "{$intl: ADDRESS-LOOKUP.MODALS.CANT-FIND-ADDRESS.TITLE}",
        "icon": "@@apiGatewayUrl/@@product/@@client/assets/images/libertyIreland/libertyIreland-info-header.svg",
        "showButton": true,
        "content": []
      }
    },
    "forms": {
      "questions:address": [
        {
          "key": "addressForm",
          "fieldGroup": [
            {
              "key": "address",
              "type": "address-lookup",
              "resetOnHide": true,
              "hideExpression": "model.enterManually === true || model.enterEirCode === true",
              "templateOptions": {
                "addressSaveTo": "address",
                "endpoints": {
                  "autocomplete": "@@nginxPrefix/geo/autocomplete",
                  "findaddress": "@@nginxPrefix/ie/geo/address"
                },
                "additionalHeaders": {
                  "x-api-key": "@@xApiKey"
                },
                "placeholder": "{$intl: ADDRESS-LOOKUP.INPUTS.ADDRESS.PLACEHOLDER}",
                "required": true,
                "noFloatingLabel": true,
                "hideRequiredMarker": true,
                "addressLookupIcon": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/liberty-icons-address.svg"
              },
              "validators": {
                "validation": ["valid-address"]
              }
            },
            {
              "key": "eircodeOnly",
              "type": "address-lookup",
              "resetOnHide": true,
              "hideExpression": "model.enterEirCode !== true",
              "templateOptions": {
                "addressSaveTo": "address",
                "endpoints": {
                  "autocomplete": "@@nginxPrefix/geo/autocomplete",
                  "findaddress": "@@nginxPrefix/ie/geo/address"
                },
                "additionalHeaders": {
                  "x-api-key": "@@xApiKey"
                },
                "placeholder": "{$intl: ADDRESS-LOOKUP.INPUTS.ADDRESS.PLACEHOLDER}",
                "required": true,
                "noFloatingLabel": true,
                "hideRequiredMarker": true,
                "addressLookupIcon": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/liberty-icons-address.svg"
              },
              "validators": {
                "validation": ["valid-address"]
              }
            },
            {
              "key": "address",
              "wrappers": ["address-lookup"],
              "resetOnHide": true,
              "hideExpression": "model.enterManually !== true",
              "templateOptions": {
                "addressSaveTo": "address"
              },
              "fieldGroup": [
                {
                  "key": "addressLine1",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: MANUAL-ADDRESS.INPUTS.ADDRESS-LINE-1.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "maxLength": 100
                  }
                },
                {
                  "key": "addressLine2",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: MANUAL-ADDRESS.INPUTS.ADDRESS-LINE-2.PLACEHOLDER}",
                    "maxLength": 100
                  }
                },
                {
                  "key": "city",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: MANUAL-ADDRESS.INPUTS.CITY.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "maxLength": 76
                  }
                },
                {
                  "key": "countyCode",
                  "type": "select",
                  "templateOptions": {
                    "label": "{$intl: MANUAL-ADDRESS.INPUTS.COUNTY.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "options": []
                  }
                },
                {
                  "key": "eircode",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: MANUAL-ADDRESS.INPUTS.EIRCODE.PLACEHOLDER}",
                    "pattern": "(?:^[AC-FHKNPRTV-Yac-fhknprtv-y][0-9]{2}|[Dd]6[Ww])[ -]?[0-9AC-FHKNPRTV-Yac-fhknprtv-y]{4}$"
                  }
                }
              ]
            },
            {
              "hideExpression": "model.enterManually === true || model.enterEirCode === true",
              "content": [
                {
                  "type": "div",
                  "className": "mb-0 mt-2 information-text",
                  "content": [
                    {
                      "type": "text",
                      "content": "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-ADDRESS-MANUALLY-PRE-TEXT}"
                    },
                    {
                      "className": "underline",
                      "type": "page-event-button",
                      "event": "ManualEntryA",
                      "content": [
                        "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-ADDRESS-MANUALLY-TEXT}"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "hideExpression": "model.enterManually !== true",
              "content": [
                {
                  "type": "div",
                  "className": "mb-0 mt-2 information-text",
                  "content": [
                    {
                      "type": "text",
                      "content": "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-EIRCODE-MANUALLY-PRE-TEXT}"
                    },
                    {
                      "className": "data-notice-confirmation",
                      "type": "page-event-button",
                      "event": "ManualEirCode",
                      "content": [
                        "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-EIRCODE-MANUALLY-TEXT}"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "key": "samePostalAddress",
              "type": "select-buttons-attached",
              "templateOptions": {
                "label": "{$intl: ADDRESS-LOOKUP.TEXT.HAS-SAME-POSTAL-ADDRESS}",
                "hideRequiredMarker": true,
                "alignCenter": true,
                "required": true,
                "options": [
                  {
                    "label": "{$intl: ADDRESS-LOOKUP.BUTTONS.YES}",
                    "value": true
                  },
                  {
                    "label": "{$intl: ADDRESS-LOOKUP.BUTTONS.NO}",
                    "value": false
                  }
                ]
              }
            },
            {
              "key": "customerAddress",
              "type": "address-lookup",
              "resetOnHide": true,
              "hideExpression": "model.samePostalAddress !== false || model.enterCustomerManually === true || model.enterCustomerEirCode === true",
              "templateOptions": {
                "addressSaveTo": "customerAddress",
                "endpoints": {
                  "autocomplete": "@@nginxPrefix/geo/autocomplete",
                  "findaddress": "@@nginxPrefix/ie/geo/address"
                },
                "additionalHeaders": {
                  "x-api-key": "@@xApiKey"
                },
                "placeholder": "{$intl: CUSTOMER-ADDRESS-LOOKUP.TEXT.ENTER-NEW-POSTAL-ADDRESS}",
                "label": "{$intl: CUSTOMER-ADDRESS-LOOKUP.TEXT.ENTER-NEW-POSTAL-ADDRESS}",
                "required": true,
                "noFloatingLabel": true,
                "hideRequiredMarker": true,
                "addressLookupIcon": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/liberty-icons-address.svg"
              },
              "validators": {
                "validation": ["valid-address"]
              }
            },
            {
              "key": "customereircodeOnly",
              "type": "address-lookup",
              "resetOnHide": true,
              "hideExpression": "model.samePostalAddress !== false || model.enterCustomerEirCode !== true",
              "templateOptions": {
                "addressSaveTo": "customerAddress",
                "endpoints": {
                  "autocomplete": "@@nginxPrefix/geo/autocomplete",
                  "findaddress": "@@nginxPrefix/ie/geo/address"
                },
                "additionalHeaders": {
                  "x-api-key": "@@xApiKey"
                },
                "placeholder": "{$intl: CUSTOMER-ADDRESS-LOOKUP.TEXT.ENTER-NEW-POSTAL-ADDRESS}",
                "label": "{$intl: CUSTOMER-ADDRESS-LOOKUP.TEXT.ENTER-NEW-POSTAL-ADDRESS}",
                "required": true,
                "noFloatingLabel": true,
                "hideRequiredMarker": true,
                "addressLookupIcon": "@@apiGatewayUrl/@@product/@@client/assets/images/icons/liberty-icons-address.svg"
              },
              "validators": {
                "validation": ["valid-address"]
              }
            },
            {
              "key": "customerAddress",
              "wrappers": ["address-lookup"],
              "resetOnHide": true,
              "hideExpression": "model.samePostalAddress !== false || model.enterCustomerManually !== true",
              "templateOptions": {
                "addressSaveTo": "customerAddress"
              },
              "fieldGroup": [
                {
                  "key": "addressLine1",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: CUSTOMER-MANUAL-ADDRESS.INPUTS.ADDRESS-LINE-1.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "maxLength": 101
                  }
                },
                {
                  "key": "addressLine2",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: CUSTOMER-MANUAL-ADDRESS.INPUTS.ADDRESS-LINE-2.PLACEHOLDER}",
                    "maxLength": 101
                  }
                },
                {
                  "key": "city",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: CUSTOMER-MANUAL-ADDRESS.INPUTS.CITY.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "maxLength": 76
                  }
                },
                {
                  "key": "countyCode",
                  "type": "select",
                  "templateOptions": {
                    "label": "{$intl: CUSTOMER-MANUAL-ADDRESS.INPUTS.COUNTY.PLACEHOLDER}",
                    "required": true,
                    "hideRequiredMarker": true,
                    "options": []
                  }
                },
                {
                  "key": "eircode",
                  "type": "input",
                  "templateOptions": {
                    "label": "{$intl: CUSTOMER-MANUAL-ADDRESS.INPUTS.EIRCODE.PLACEHOLDER}",
                    "pattern": "(?:^[AC-FHKNPRTV-Yac-fhknprtv-y][0-9]{2}|[Dd]6[Ww])[ -]?[0-9AC-FHKNPRTV-Yac-fhknprtv-y]{4}$"
                  }
                }
              ]
            },
            {
              "hideExpression": "model.samePostalAddress !== false || model.enterCustomerManually === true || model.enterCustomerEirCode === true",
              "content": [
                {
                  "type": "div",
                  "className": "mb-0 mt-2 information-text",
                  "content": [
                    {
                      "type": "text",
                      "content": "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-ADDRESS-MANUALLY-PRE-TEXT}"
                    },
                    {
                      "className": "underline",
                      "type": "page-event-button",
                      "event": "ManualCustomerEntry",
                      "content": [
                        "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-ADDRESS-MANUALLY-TEXT}"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "hideExpression": "model.samePostalAddress !== false || model.enterCustomerManually !== true",
              "content": [
                {
                  "type": "div",
                  "className": "mb-0 mt-2 information-text",
                  "content": [
                    {
                      "type": "text",
                      "content": "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-EIRCODE-MANUALLY-PRE-TEXT}"
                    },
                    {
                      "className": "data-notice-confirmation",
                      "type": "page-event-button",
                      "event": "ManualCustomerEirCode",
                      "content": [
                        "{$intl: ADDRESS-LOOKUP.TEXT.ENTER-EIRCODE-MANUALLY-TEXT}"
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "@submit"
        }
      ]
    }
  },
  "$schema": "https://gde-digital-sales-core-docs.aws.lmig.com/schema/v1/question.schema.json"
}
